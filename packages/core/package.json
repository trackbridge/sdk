{
  "name": "@trackbridge/core",
  "version": "0.0.3",
  "description": "Shared types, normalization, and hashing for Trackbridge",
  "license": "MIT",
  "homepage": "https://trackbridge.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/trackbridge/sdk.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
