# Copy to .env.local and fill in the real values.
#
# Browser-exposed (read by the client tracker). NEXT_PUBLIC_* is required
# so Next.js inlines these into the client bundle.
NEXT_PUBLIC_ADS_CONVERSION_ID=AW-123456789
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADS_CONVERSION_LABEL=AbCdEfGhIjK

# Server-only — never exposed to the browser.
GA4_API_SECRET=...

GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_REFRESH_TOKEN=1//0g...
GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...

# The Ads-API resource name for the same conversion. Find it in the Ads UI
# under Tools → Conversions; the format is:
# customers/{customerId}/conversionActions/{conversionActionId}
GOOGLE_ADS_CONVERSION_ACTION=customers/1234567890/conversionActions/9876543210
